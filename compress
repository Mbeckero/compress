#!/bin/bash
# ═══════════════════════════════════════════════════════════════
# compress — Video compressor CLI v5
# Interactive preset selection + real-time progress
# Always preserves original resolution and FPS
# ═══════════════════════════════════════════════════════════════

set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

PRESET=""; CRF=23; MAX_MB=0; SKIP_CONFIRM=false; INTERACTIVE=true; FILES=()

show_help() {
  echo ""
  echo -e "${BOLD}compress${NC} — Video compressor CLI v5"
  echo ""
  echo -e "${BOLD}USO:${NC}"
  echo "  compress archivo.mov                    # modo interactivo"
  echo "  compress archivo.mov --fast             # directo, sin menú"
  echo "  compress archivo.mov --fast --max 500   # directo con tope"
  echo "  compress *.mov --fast -y                # batch sin preguntas"
  echo ""
  echo -e "${BOLD}PRESETS:${NC}"
  echo -e "  --ultrafast   Velocísimo, archivo más grande"
  echo -e "  --fast        Rápido, buen balance"
  echo -e "  --medium      Balance óptimo"
  echo -e "  --slow        Lento, máxima compresión"
  echo ""
  echo -e "${BOLD}OPCIONES:${NC}"
  echo "  --max <MB>    Tamaño máximo en MB (activa two-pass)"
  echo "  --crf <N>     CRF manual (18-28, default: 23)"
  echo "  --yes, -y     Saltar confirmación"
  echo "  --help        Muestra esta ayuda"
  echo ""
  echo -e "${DIM}Sin flags → modo interactivo con menú de opciones${NC}"
  echo -e "${DIM}Con flags → modo directo (ideal para batch)${NC}"
  echo ""
}

print_sep() { echo -e "${DIM}──────────────────────────────────────────────────${NC}"; }

fmt_size() {
  local b=$1
  if [ "$b" -gt 1073741824 ]; then echo "$(echo "scale=2; $b/1073741824" | bc) GB"
  elif [ "$b" -gt 1048576 ]; then echo "$(echo "scale=1; $b/1048576" | bc) MB"
  else echo "$(echo "scale=0; $b/1024" | bc) KB"; fi
}

fmt_time() {
  local s=$1
  if [ "$s" -ge 3600 ]; then printf "%dh %02dm %02ds" $((s/3600)) $((s%3600/60)) $((s%60))
  elif [ "$s" -ge 60 ]; then printf "%dm %02ds" $((s/60)) $((s%60))
  else printf "%ds" "$s"; fi
}

# ── Estimar tiempo de encoding ──
est_encode_time() {
  local dur=$1 preset=$2 codec=$3
  # Speeds aprox en x-realtime para M-series, H.264 source
  # H.265 source encodea ~30% más rápido
  python3 -c "
dur=$dur
preset='$preset'
codec='$codec'
speeds = {'ultrafast': 3.5, 'fast': 1.0, 'medium': 0.5, 'slow': 0.2}
spd = speeds.get(preset, 0.5)
if codec == 'hevc': spd *= 1.3
secs = int(dur / spd)
print(secs)"
}

# ── Real-time progress bar ──
show_progress() {
  local TOTAL_DUR=$1
  local START_TS=$(date +%s)
  local BAR_WIDTH=30

  while IFS='=' read -r key value; do
    if [ "$key" = "out_time" ]; then
      local CURRENT_SECS=$(python3 -c "
parts='$value'.strip().split(':')
if len(parts)==3:
    h,m=int(parts[0]),int(parts[1])
    s=float(parts[2])
    print(max(0,h*3600+m*60+s))
else: print(0)" 2>/dev/null || echo "0")

      local PCT=$(python3 -c "
cur=$CURRENT_SECS; total=$TOTAL_DUR
p=min(cur/total*100,100) if total>0 else 0
print(f'{p:.1f}')" 2>/dev/null)

      local PCT_INT=$(echo "$PCT" | cut -d. -f1)
      PCT_INT=${PCT_INT:-0}

      local NOW=$(date +%s)
      local ELAPSED=$((NOW - START_TS))
      local ETA_STR=""

      if [ "$PCT_INT" -gt 2 ] && [ "$ELAPSED" -gt 3 ]; then
        local ETA_SECS=$(python3 -c "
elapsed=$ELAPSED; pct=$PCT
remaining=int(elapsed*(100-pct)/pct) if pct>0 else 0
print(remaining)" 2>/dev/null)
        ETA_STR=$(fmt_time "$ETA_SECS")
      else
        ETA_STR="calculando..."
      fi

      local FILLED=$(( PCT_INT * BAR_WIDTH / 100 ))
      local EMPTY=$(( BAR_WIDTH - FILLED ))
      local BAR=""
      for ((i=0; i<FILLED; i++)); do BAR+="█"; done
      for ((i=0; i<EMPTY; i++)); do BAR+="░"; done

      printf "\r  ${CYAN}${BAR}${NC} ${BOLD}%5s%%${NC}  ${DIM}ETA: %-15s${NC}" "$PCT" "$ETA_STR"
    fi
  done

  local END_TS=$(date +%s)
  local TOTAL_ELAPSED=$((END_TS - START_TS))
  printf "\r  ${GREEN}"
  for ((i=0; i<BAR_WIDTH; i++)); do printf "█"; done
  printf "${NC} ${BOLD}100.0%%${NC}  ${DIM}$(fmt_time $TOTAL_ELAPSED)${NC}       \n"
}

# ── Parse args ──
while [[ $# -gt 0 ]]; do
  case "$1" in
    --ultrafast) PRESET="ultrafast"; INTERACTIVE=false; shift ;;
    --fast)      PRESET="fast"; INTERACTIVE=false; shift ;;
    --medium)    PRESET="medium"; INTERACTIVE=false; shift ;;
    --slow)      PRESET="slow"; INTERACTIVE=false; shift ;;
    --max)       MAX_MB="$2"; INTERACTIVE=false; shift 2 ;;
    --crf)       CRF="$2"; shift 2 ;;
    --yes|-y)    SKIP_CONFIRM=true; shift ;;
    --help|-h)   show_help; exit 0 ;;
    -*)          echo -e "${RED}Error: opción desconocida '$1'${NC}"; show_help; exit 1 ;;
    *)           FILES+=("$1"); shift ;;
  esac
done

if [ ${#FILES[@]} -eq 0 ]; then
  echo -e "${RED}Error: no especificaste ningún archivo${NC}"; show_help; exit 1
fi
if ! command -v ffmpeg &>/dev/null; then
  echo -e "${RED}Error: ffmpeg no instalado. brew install ffmpeg${NC}"; exit 1
fi

TOTAL_FILES=${#FILES[@]}; CURRENT=0; TOTAL_SAVED=0

for INPUT in "${FILES[@]}"; do
  CURRENT=$((CURRENT + 1))
  echo ""
  [ "$TOTAL_FILES" -gt 1 ] && echo -e "${BOLD}${CYAN}[$CURRENT/$TOTAL_FILES]${NC}"

  if [ ! -f "$INPUT" ]; then
    echo -e "${RED}✗ No encontrado: $INPUT${NC}"; continue
  fi

  # ── Metadata ──
  PROBE=$(ffprobe -v error \
    -show_entries format=duration,size,bit_rate \
    -show_entries stream=codec_name,codec_type,width,height,r_frame_rate,bit_rate \
    -of json "$INPUT" 2>/dev/null)

  DURATION=$(echo "$PROBE" | python3 -c "import sys,json; print(json.load(sys.stdin)['format']['duration'])")
  FILE_SIZE=$(echo "$PROBE" | python3 -c "import sys,json; print(json.load(sys.stdin)['format']['size'])")

  V_WIDTH=$(echo "$PROBE" | python3 -c "
import sys,json; s=json.load(sys.stdin)['streams']
v=[x for x in s if x['codec_type']=='video']
print(v[0]['width'] if v else 0)")

  V_HEIGHT=$(echo "$PROBE" | python3 -c "
import sys,json; s=json.load(sys.stdin)['streams']
v=[x for x in s if x['codec_type']=='video']
print(v[0]['height'] if v else 0)")

  V_CODEC=$(echo "$PROBE" | python3 -c "
import sys,json; s=json.load(sys.stdin)['streams']
v=[x for x in s if x['codec_type']=='video']
print(v[0]['codec_name'] if v else 'unknown')")

  V_FPS_RAW=$(echo "$PROBE" | python3 -c "
import sys,json; s=json.load(sys.stdin)['streams']
v=[x for x in s if x['codec_type']=='video']
print(v[0]['r_frame_rate'] if v else '0/1')")

  V_FPS=$(python3 -c "n,d='$V_FPS_RAW'.split('/'); print(round(int(n)/int(d),2))")

  V_BITRATE=$(echo "$PROBE" | python3 -c "
import sys,json; s=json.load(sys.stdin)['streams']
v=[x for x in s if x['codec_type']=='video']
print(v[0].get('bit_rate','0') if v else '0')")

  DURATION_INT=$(echo "$DURATION" | cut -d. -f1)
  SIZE_HUMAN=$(fmt_size "$FILE_SIZE")
  DUR_HUMAN=$(fmt_time "$DURATION_INT")
  V_BR_HUMAN=$(echo "scale=1; ${V_BITRATE:-0}/1000000" | bc 2>/dev/null || echo "?")

  # ── Video info ──
  print_sep
  echo -e "${BOLD}📹 Input:${NC} $(basename "$INPUT")"
  echo -e "   ${DIM}${V_WIDTH}x${V_HEIGHT} · ${V_FPS}fps · ${V_CODEC} · ${V_BR_HUMAN} Mbps${NC}"
  echo -e "   ${DIM}${SIZE_HUMAN} · ${DUR_HUMAN}${NC}"
  echo -e "   ${DIM}Calidad preservada: ${V_WIDTH}x${V_HEIGHT} · ${V_FPS}fps${NC}"
  print_sep

  # ════════════════════════════════════════════════
  # ── MENÚ INTERACTIVO (si no pasaron flags) ──
  # ════════════════════════════════════════════════
  if [ "$INTERACTIVE" = true ]; then

    # Estimar tiempos para cada preset
    T_UF=$(est_encode_time "$DURATION_INT" "ultrafast" "$V_CODEC")
    T_FA=$(est_encode_time "$DURATION_INT" "fast" "$V_CODEC")
    T_ME=$(est_encode_time "$DURATION_INT" "medium" "$V_CODEC")
    T_SL=$(est_encode_time "$DURATION_INT" "slow" "$V_CODEC")

    echo ""
    echo -e "${BOLD}⚡ Velocidad:${NC}"
    echo -e "   ${CYAN}1)${NC} ultrafast   ⚡⚡⚡⚡  ~$(fmt_time $T_UF)   ${DIM}archivo más grande${NC}"
    echo -e "   ${CYAN}2)${NC} fast        ⚡⚡⚡    ~$(fmt_time $T_FA)   ${DIM}buen balance${NC}"
    echo -e "   ${CYAN}3)${NC} medium      ⚡⚡      ~$(fmt_time $T_ME)   ${DIM}balance óptimo${NC}"
    echo -e "   ${CYAN}4)${NC} slow        ⚡        ~$(fmt_time $T_SL)   ${DIM}máxima compresión${NC}"
    echo ""
    echo -ne "   ${BOLD}Elige [1-4]${NC} ${DIM}(Enter = 2 fast):${NC} "
    read -r SPEED_CHOICE
    SPEED_CHOICE=${SPEED_CHOICE:-2}

    case "$SPEED_CHOICE" in
      1) PRESET="ultrafast" ;;
      2) PRESET="fast" ;;
      3) PRESET="medium" ;;
      4) PRESET="slow" ;;
      *) PRESET="fast"; echo -e "   ${DIM}→ fast${NC}" ;;
    esac

    echo ""
    echo -e "${BOLD}📏 Tamaño máximo:${NC}"
    echo -e "   ${CYAN}1)${NC} Sin límite          ${DIM}CRF 23, tamaño variable${NC}"
    echo -e "   ${CYAN}2)${NC} Máx 500 MB          ${DIM}ideal para compartir${NC}"
    echo -e "   ${CYAN}3)${NC} Máx 400 MB          ${DIM}más compacto${NC}"
    echo -e "   ${CYAN}4)${NC} Máx 300 MB          ${DIM}agresivo${NC}"
    echo -e "   ${CYAN}5)${NC} Custom              ${DIM}ingresa tu tope${NC}"
    echo ""
    echo -ne "   ${BOLD}Elige [1-5]${NC} ${DIM}(Enter = 1):${NC} "
    read -r SIZE_CHOICE
    SIZE_CHOICE=${SIZE_CHOICE:-1}

    case "$SIZE_CHOICE" in
      1) MAX_MB=0 ;;
      2) MAX_MB=500 ;;
      3) MAX_MB=400 ;;
      4) MAX_MB=300 ;;
      5)
        echo -ne "   ${BOLD}Tamaño máximo en MB:${NC} "
        read -r CUSTOM_MB
        MAX_MB=${CUSTOM_MB:-0}
        ;;
      *) MAX_MB=0 ;;
    esac

    echo ""
    echo -e "${BOLD}🎨 Calidad (CRF):${NC}"
    echo -e "   ${CYAN}1)${NC} Alta        CRF 20  ${DIM}casi lossless, archivo grande${NC}"
    echo -e "   ${CYAN}2)${NC} Muy buena   CRF 22  ${DIM}excelente calidad${NC}"
    echo -e "   ${CYAN}3)${NC} Buena       CRF 23  ${DIM}recomendado${NC}"
    echo -e "   ${CYAN}4)${NC} Eficiente   CRF 25  ${DIM}buena calidad, más compacto${NC}"
    echo -e "   ${CYAN}5)${NC} Compacta    CRF 28  ${DIM}aceptable, muy liviano${NC}"
    echo ""
    echo -ne "   ${BOLD}Elige [1-5]${NC} ${DIM}(Enter = 3):${NC} "
    read -r CRF_CHOICE
    CRF_CHOICE=${CRF_CHOICE:-3}

    case "$CRF_CHOICE" in
      1) CRF=20 ;;
      2) CRF=22 ;;
      3) CRF=23 ;;
      4) CRF=25 ;;
      5) CRF=28 ;;
      *) CRF=23 ;;
    esac
  fi

  # Default preset si aún está vacío
  [ -z "$PRESET" ] && PRESET="medium"

  # ── Output path ──
  DIR=$(dirname "$INPUT"); BASENAME=$(basename "$INPUT"); NAME="${BASENAME%.*}"
  OUTPUT="$DIR/${NAME}_compressed.mp4"
  if [ -f "$OUTPUT" ]; then
    C=1; while [ -f "$DIR/${NAME}_compressed_${C}.mp4" ]; do C=$((C+1)); done
    OUTPUT="$DIR/${NAME}_compressed_${C}.mp4"
  fi

  # ── Resumen de configuración ──
  echo ""
  print_sep
  echo -e "${BOLD}🔧 Configuración final:${NC}"
  echo -e "   ${DIM}Velocidad:${NC}  ${CYAN}${PRESET}${NC}"
  echo -e "   ${DIM}Calidad:${NC}    CRF ${CYAN}${CRF}${NC}"
  if [ "$MAX_MB" -gt 0 ]; then
    echo -e "   ${DIM}Tope:${NC}       ${CYAN}${MAX_MB} MB${NC} (two-pass)"
  else
    echo -e "   ${DIM}Tope:${NC}       sin límite"
  fi
  echo -e "   ${DIM}Resolución:${NC} ${GREEN}${V_WIDTH}x${V_HEIGHT}${NC} ${DIM}(preservada)${NC}"
  echo -e "   ${DIM}FPS:${NC}        ${GREEN}${V_FPS}${NC} ${DIM}(preservado)${NC}"
  echo -e "   ${DIM}Output:${NC}     $(basename "$OUTPUT")"
  print_sep

  # ── Estrategia ──
  USE_TWO_PASS=false; TARGET_BITRATE=0
  if [ "$MAX_MB" -gt 0 ]; then
    TARGET_BITRATE=$(python3 -c "
dur=$DURATION; vbps=int(($MAX_MB*1048576*8)/dur)-128000
print(max(vbps//1000,500))")
    [ "$TARGET_BITRATE" -lt 5000 ] && USE_TWO_PASS=true
  fi

  # ── Estimación: 3 muestras ──
  SAMPLE_DUR=10
  if [ "$DURATION_INT" -lt 40 ]; then
    SAMPLE_DUR=$(( DURATION_INT / 4 ))
    [ "$SAMPLE_DUR" -lt 3 ] && SAMPLE_DUR=3
  fi

  POS1=$(python3 -c "print(int($DURATION * 0.20))")
  POS2=$(python3 -c "print(int($DURATION * 0.50))")
  POS3=$(python3 -c "print(int($DURATION * 0.80))")

  echo ""
  echo -e "${DIM}🔍 Estimando tamaño (3 muestras × ${SAMPLE_DUR}s)...${NC}"

  if [ "$USE_TWO_PASS" = true ]; then
    EST_SIZE=$(python3 -c "print(int(($TARGET_BITRATE*1000+128000)*$DURATION/8))")
  else
    TOTAL_SAMPLE_BYTES=0; TOTAL_SAMPLE_SECS=0; SAMPLE_OK=0

    for POS in $POS1 $POS2 $POS3; do
      SFILE="/tmp/compress_s_${$}_${POS}.mp4"
      ffmpeg -y -ss "$POS" -i "$INPUT" -t "$SAMPLE_DUR" \
        -c:v libx265 -crf "$CRF" -preset ultrafast \
        -vf "scale=${V_WIDTH}:${V_HEIGHT}" -r "$V_FPS" \
        -c:a aac -b:a 128k -tag:v hvc1 \
        "$SFILE" 2>/dev/null

      if [ -f "$SFILE" ]; then
        SBYTES=$(stat -f%z "$SFILE" 2>/dev/null || stat -c%s "$SFILE")
        TOTAL_SAMPLE_BYTES=$((TOTAL_SAMPLE_BYTES + SBYTES))
        TOTAL_SAMPLE_SECS=$((TOTAL_SAMPLE_SECS + SAMPLE_DUR))
        SAMPLE_OK=$((SAMPLE_OK + 1))
        rm -f "$SFILE"
      fi
    done

    if [ "$SAMPLE_OK" -gt 0 ] && [ "$TOTAL_SAMPLE_SECS" -gt 0 ]; then
      EST_SIZE=$(python3 -c "
total_bytes=$TOTAL_SAMPLE_BYTES
sample_secs=$TOTAL_SAMPLE_SECS
total_dur=$DURATION
preset='$PRESET'
factors={'ultrafast':1.0,'fast':0.90,'medium':0.82,'slow':0.75}
factor=factors.get(preset,0.82)
bps=total_bytes/sample_secs
estimated=bps*total_dur*factor
print(int(estimated))")
    else
      EST_SIZE=0
    fi
  fi

  if [ "$EST_SIZE" -gt 0 ]; then
    EST_HUMAN=$(fmt_size "$EST_SIZE")
    EST_RED=$(python3 -c "print(round((1-$EST_SIZE/$FILE_SIZE)*100,1))")
    EST_SAVED_H=$(fmt_size "$(python3 -c "print(int($FILE_SIZE-$EST_SIZE))")")

    echo ""
    echo -e "${BOLD}📊 Estimación:${NC}"
    echo -e "   ${DIM}Tamaño actual:${NC}   $SIZE_HUMAN"
    echo -e "   ${DIM}Tamaño estimado:${NC} ${BOLD}${GREEN}~${EST_HUMAN}${NC}"
    echo -e "   ${DIM}Ahorro estimado:${NC} ${GREEN}~${EST_SAVED_H} (-${EST_RED}%)${NC}"
    [ "$USE_TWO_PASS" = true ] && echo -e "   ${DIM}Modo:${NC} two-pass (${TARGET_BITRATE}k)"

    if [ "$MAX_MB" -gt 0 ]; then
      EST_MB=$(python3 -c "print(round($EST_SIZE/1048576,1))")
      if (( $(echo "$EST_MB > $MAX_MB" | bc -l) )); then
        echo -e "   ${YELLOW}⚠ Podría exceder ${MAX_MB}MB — se usará two-pass para garantizar${NC}"
        USE_TWO_PASS=true
        TARGET_BITRATE=$(python3 -c "
dur=$DURATION; vbps=int(($MAX_MB*1048576*8)/dur)-128000
print(max(vbps//1000,500))")
      else
        echo -e "   ${GREEN}✓ Dentro del tope de ${MAX_MB}MB${NC}"
      fi
    fi
  fi

  if [ "$SKIP_CONFIRM" = false ]; then
    echo ""
    echo -ne "${BOLD}¿Iniciar compresión? [S/n]:${NC} "
    read -r REPLY; REPLY=${REPLY:-S}
    [[ ! "$REPLY" =~ ^[SsYy]$ ]] && echo -e "${YELLOW}⏭ Saltado${NC}" && continue
  fi

  echo ""
  START_TIME=$(date +%s)

  # ── Comprimir ──
  if [ "$USE_TWO_PASS" = true ]; then
    echo -e "${DIM}Pass 1/2${NC}"
    ffmpeg -y -i "$INPUT" \
      -c:v libx265 -b:v ${TARGET_BITRATE}k -preset "$PRESET" \
      -vf "scale=${V_WIDTH}:${V_HEIGHT}" -r "$V_FPS" \
      -x265-params "pass=1:stats=/tmp/compress_x265.log" \
      -an -f null \
      -progress pipe:1 \
      /dev/null 2>/dev/null | show_progress "$DURATION_INT"

    echo -e "${DIM}Pass 2/2${NC}"
    ffmpeg -y -i "$INPUT" \
      -c:v libx265 -b:v ${TARGET_BITRATE}k -preset "$PRESET" \
      -vf "scale=${V_WIDTH}:${V_HEIGHT}" -r "$V_FPS" \
      -x265-params "pass=2:stats=/tmp/compress_x265.log" \
      -c:a aac -b:a 128k -tag:v hvc1 -movflags +faststart \
      -progress pipe:1 \
      "$OUTPUT" 2>/dev/null | show_progress "$DURATION_INT"
    rm -f /tmp/compress_x265.log /tmp/compress_x265.log.cutree

  else
    ffmpeg -y -i "$INPUT" \
      -c:v libx265 -crf "$CRF" -preset "$PRESET" \
      -vf "scale=${V_WIDTH}:${V_HEIGHT}" -r "$V_FPS" \
      -c:a aac -b:a 128k -tag:v hvc1 -movflags +faststart \
      -progress pipe:1 \
      "$OUTPUT" 2>/dev/null | show_progress "$DURATION_INT"
  fi

  END_TIME=$(date +%s); ELAPSED=$((END_TIME - START_TIME))

  if [ ! -f "$OUTPUT" ]; then
    echo -e "${RED}✗ Error: no se generó el archivo${NC}"; continue
  fi

  # ── Resultado ──
  OUT_SIZE=$(stat -f%z "$OUTPUT" 2>/dev/null || stat -c%s "$OUTPUT")
  OUT_PROBE=$(ffprobe -v error -show_entries format=bit_rate -of json "$OUTPUT" 2>/dev/null)
  OUT_SIZE_HUMAN=$(fmt_size "$OUT_SIZE")
  REDUCTION=$(python3 -c "print(round((1-$OUT_SIZE/$FILE_SIZE)*100,1))")
  SAVED_BYTES=$((FILE_SIZE - OUT_SIZE))
  SAVED_HUMAN=$(fmt_size "$SAVED_BYTES")
  TOTAL_SAVED=$((TOTAL_SAVED + SAVED_BYTES))

  OUT_BR=$(echo "$OUT_PROBE" | python3 -c "
import sys,json; print(json.load(sys.stdin)['format'].get('bit_rate','0'))" 2>/dev/null)
  OUT_BR_HUMAN=$(echo "scale=1; ${OUT_BR:-0}/1000000" | bc 2>/dev/null || echo "?")

  # Verificar resolución y FPS del output
  OUT_CHECK=$(ffprobe -v error \
    -show_entries stream=width,height,r_frame_rate \
    -select_streams v:0 -of json "$OUTPUT" 2>/dev/null)
  OUT_W=$(echo "$OUT_CHECK" | python3 -c "import sys,json; print(json.load(sys.stdin)['streams'][0]['width'])" 2>/dev/null)
  OUT_H=$(echo "$OUT_CHECK" | python3 -c "import sys,json; print(json.load(sys.stdin)['streams'][0]['height'])" 2>/dev/null)
  OUT_FPS_RAW=$(echo "$OUT_CHECK" | python3 -c "import sys,json; print(json.load(sys.stdin)['streams'][0]['r_frame_rate'])" 2>/dev/null)
  OUT_FPS=$(python3 -c "n,d='$OUT_FPS_RAW'.split('/'); print(round(int(n)/int(d),2))" 2>/dev/null)

  EST_ACC=""
  if [ "$EST_SIZE" -gt 0 ]; then
    EST_ACC=$(python3 -c "print(f'{100-abs($EST_SIZE-$OUT_SIZE)/$OUT_SIZE*100:.1f}')")
  fi

  echo ""
  echo -e "${GREEN}${BOLD}✓ Compresión exitosa${NC}"
  print_sep
  echo -e "  ${DIM}Antes:${NC}      $SIZE_HUMAN  (${V_BR_HUMAN} Mbps)"
  echo -e "  ${DIM}Después:${NC}    ${BOLD}$OUT_SIZE_HUMAN${NC}  (${OUT_BR_HUMAN} Mbps)"
  echo -e "  ${DIM}Ahorro:${NC}     ${GREEN}${SAVED_HUMAN} (-${REDUCTION}%)${NC}"
  echo -e "  ${DIM}Tiempo:${NC}     $(fmt_time $ELAPSED)"
  [ -n "$EST_ACC" ] && echo -e "  ${DIM}Precisión:${NC}  ${EST_ACC}% vs estimación"
  echo -e "  ${DIM}Resolución:${NC} ${GREEN}${OUT_W}x${OUT_H}${NC} ✓"
  echo -e "  ${DIM}FPS:${NC}        ${GREEN}${OUT_FPS}${NC} ✓"
  echo -e "  ${DIM}Output:${NC}     $OUTPUT"

  if [ "$MAX_MB" -gt 0 ]; then
    OUT_MB=$(python3 -c "print(round($OUT_SIZE/1048576,1))")
    if (( $(echo "$OUT_MB > $MAX_MB" | bc -l) )); then
      echo -e "  ${YELLOW}⚠ Excede ${MAX_MB}MB (${OUT_MB}MB). Prueba --slow o --crf $((CRF+2))${NC}"
    else
      echo -e "  ${GREEN}✓ Dentro del tope de ${MAX_MB}MB${NC}"
    fi
  fi
  print_sep

done

if [ "$TOTAL_FILES" -gt 1 ]; then
  echo ""
  echo -e "${BOLD}${GREEN}═══ Batch completado: $TOTAL_FILES archivos ═══${NC}"
  echo -e "  Ahorro total: ${GREEN}$(fmt_size $TOTAL_SAVED)${NC}"
  echo ""
fi
